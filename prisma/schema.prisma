generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum GoalScope {
  DAILY
  WEEKLY
}

enum GoalMatchType {
  TAG
  PROJECT
  TASK
  CUSTOM
}

enum DayTaskStatus {
  ACTIVE
  COMPLETED
}

enum TimeEntrySource {
  TIMER
  MANUAL
}

enum WidgetDisplayMode {
  ACTUAL
  PLANNED
}

model User {
  id               String            @id @default(cuid())
  username         String            @unique
  passwordHash     String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sessions         Session[]
  settings         UserSettings?
  areas            Area[]
  projects         Project[]
  tasks            Task[]
  goals            Goal[]
  dashboardWidgets DashboardWidget[]
  dayPlans         DayPlan[]
  dayTasks         DayTask[]
  scheduleBlocks   ScheduleBlock[]
  timeEntries      TimeEntry[]
  templates        Template[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  dayStartMin      Int      @default(360)
  dayEndMin        Int      @default(1380)
  timerRoundingMin Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Area {
  id        String    @id @default(cuid())
  userId    String
  name      String
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects  Project[]

  @@index([userId, order])
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  areaId    String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  area      Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([userId, areaId, order])
}

model Task {
  id                 String          @id @default(cuid())
  userId             String
  projectId          String
  title              String
  notes              String?
  tags               Json
  defaultEstimateMin Int             @default(30)
  archived           Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dayTasks           DayTask[]
  scheduleBlocks     ScheduleBlock[]
  timeEntries        TimeEntry[]

  @@index([userId, projectId, archived])
}

model Goal {
  id              String            @id @default(cuid())
  userId          String
  name            String
  scope           GoalScope
  targetMin       Int
  matchType       GoalMatchType
  matchTagNames   Json
  matchProjectIds Json
  matchTaskIds    Json
  showOnDashboard Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets         DashboardWidget[]

  @@index([userId, showOnDashboard])
}

model DashboardWidget {
  id          String            @id @default(cuid())
  userId      String
  goalId      String
  visible     Boolean           @default(true)
  sortOrder   Int               @default(0)
  displayMode WidgetDisplayMode @default(ACTUAL)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal        Goal              @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([userId, goalId])
  @@index([userId, sortOrder])
}

model DayPlan {
  id        String   @id @default(cuid())
  userId    String
  date      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model DayTask {
  id        String        @id @default(cuid())
  userId    String
  date      String
  taskId    String
  plannedMin Int
  sortOrder Int           @default(0)
  status    DayTaskStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, date, taskId])
  @@index([userId, date])
  @@index([userId, taskId, date])
}

model ScheduleBlock {
  id        String   @id @default(cuid())
  userId    String
  date      String
  startMin  Int
  endMin    Int
  taskId    String?
  label     String?
  locked    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, date, startMin])
}

model TimeEntry {
  id        String          @id @default(cuid())
  userId    String
  date      String
  taskId    String?
  source    TimeEntrySource @default(MANUAL)
  startTs   DateTime
  endTs     DateTime?
  note      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, taskId, date])
}

model Template {
  id              String   @id @default(cuid())
  userId          String
  name            String
  weekdayMask     Json?
  dayTaskTemplate Json
  scheduleTemplate Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, name])
}



